{
  "name": "free-draw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A simple kid-friendly drawing and coloring app for tablets.",
  "scripts": {
    "dev": "node tools/server.mjs",
    "build": "node tools/build.mjs",
    "check": "node --check src/main.js && node tools/smoke-test.mjs",
    "store:assets": "npm run screenshots",
    "screenshots": "node tools/capture-screenshots.mjs"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "playwright": "^1.61.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1"
  }
}
